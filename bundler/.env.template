# ══════════════════════════════════════════════════════════════
#  Agentic Jira Ticket Analyzer v2.0 — Environment Configuration
#  Copy this file to .env and fill in your values.
#  Lines starting with # are comments — safe to leave as-is.
# ══════════════════════════════════════════════════════════════

# ── Jira Integration (REQUIRED) ────────────────────────────────
# Your Jira Cloud domain (e.g. mycompany.atlassian.net)
JIRA_DOMAIN=your-domain.atlassian.net

# Your Jira login email
JIRA_EMAIL=you@company.com

# Jira API Token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-jira-api-token

# ── LLM API Keys ───────────────────────────────────────────────
# Add the keys you have. The system picks the best available provider automatically.
# Leave ALL blank to use local Ollama only (free, offline, no data leaves your network).

# Groq — fastest free cloud tier (~7s/ticket). Recommended for demos.
# Get key at: https://console.groq.com
# GROQ_API_KEY=gsk_...

# Anthropic Claude — best analysis quality for architecture tickets.
# Get key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini — generous free tier, good all-rounder.
# Get key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AI...

# OpenAI — GPT-4o for deep architecture analysis.
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# DeepSeek — cheapest paid option, good for code analysis.
# DEEPSEEK_API_KEY=...

# ── Git Tokens (only if using gitUrl in config.yaml) ───────────
# GitHub personal access token for private repo cloning
# GIT_TOKEN=ghp_...

# ── Ollama Configuration (optional overrides) ──────────────────
# Default: http://localhost:11434
# OLLAMA_URL=http://localhost:11434

# Timeout for local model inference in milliseconds (default: 240000 = 4 min)
# Increase if your machine is slow or model is large
# OLLAMA_TIMEOUT_MS=240000

# ── Security (production mode) ─────────────────────────────────
# HMAC secret for Jira webhook verification.
# Set this + change server.env to 'production' in config.yaml for production use.
# Must match the secret you set in Jira → Settings → Webhooks.
# JIRA_WEBHOOK_SECRET=your-random-secret-here
