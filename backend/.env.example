# Duplicate this file as '.env' in the same folder and add your API keys.
# The server will automatically use the first API key it finds here,
# falling back to local Ollama if none are configured.

# 1. DeepSeek API (Recommended for fast responses)
# Get a key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# 2. Google Gemini API (Free & Fast)
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=

# 3. Groq Cloud API (Free & Extremely Fast Llama 3)
# Get a free key at: https://console.groq.com/
GROQ_API_KEY=

# 4. OpenAI API
# Get a key at: https://platform.openai.com/
OPENAI_API_KEY=

# GitHub API Context Fetching (Required if hosting backend in cloud - Option B)
# Get a Personal Access Token (Classic) at: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main

# Jira Webhook authentication (Optional: only if private board attachments need downloading)
JIRA_EMAIL=
JIRA_API_TOKEN=
